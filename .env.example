# ── Environment Variables ─────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Google Cloud project where Vertex AI and Firestore are enabled
GCP_PROJECT_ID=your-gcp-project-id

# Vertex AI region (Gemini availability: us-central1 recommended)
GCP_LOCATION=us-central1

# Gemini model to use
GEMINI_MODEL=gemini-1.5-flash-001

# Path to GCP service account JSON key (for local development)
# Leave empty if using Application Default Credentials (gcloud auth application-default login)
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
